<!-- views/pages/package3.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Third Package | Utsava Click</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/nav.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/package3.css">
</head>
<body>

    <%- include('../partials/nav') %>

    <main class="package-details-page">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="details-card">
                        <div class="details-header">
                            <h1><i class="bi bi-camera"></i> Thered Package</h1>
                            <div class="base-price">₹ 1,49,000</div>
                        </div>

                        <div class="row">
                            <div class="col-md-7">
                                <ul class="feature-list">
                                    <li><i class="bi bi-music-note-beamed"></i> Pre-wedding Song & Teaser</li>
                                    <li><i class="bi bi-calendar3"></i> 7 days Go Photos</li>
                                    <li><i class="bi bi-camera-video"></i> Candid Cinematography (only wedding day)</li>
                                    <li><i class="bi bi-book"></i> 30-page Album (2 copies)</li>
                                    <li><i class="bi bi-film"></i> All wedding videos fully edited</li>
                                    <li><i class="bi bi-lightning-charge"></i> Reels and Post</li>
                                </ul>
                            </div>
                            <div class="col-md-5">
                                <div class="location-selector">
                                    <label for="locationSelect">Select Location:</label>
                                    <select id="locationSelect" class="form-select-custom">
                                        <option value="Rajasthan">Rajasthan</option>
                                        <option value="Gujarat">Gujarat</option>
                                        <option value="Other">Other States</option>
                                    </select>
                                </div>

                                <div class="total-price-display">
                                    Total: <span id="totalPrice">₹ 1,49,000</span>
                                </div>

                                <div class="action-buttons">
                                    <a href="/booking?package=Third Package&price=149000&services=Pre-wedding Song,7 days Photos,Candid Cinematography,2x 30-page Album,All videos edited,Reels" class="btn-book-now text-center">Book Now</a>
                                    <a href="/" class="btn-back"><i class="bi bi-arrow-left"></i> Back</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <!-- Custom Scripts -->
    <script src="/js/package3.js"></script>
    <script src="/js/footer.js"></script>
    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
