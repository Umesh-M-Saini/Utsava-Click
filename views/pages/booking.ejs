<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Google Fonts: Cinzel, Playfair Display, Poppins -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/nav.css">
    <link rel="stylesheet" href="/css/booking.css">
</head>
<body>
    <!-- Include Navbar Partial -->
    <%- include('../partials/nav') %>

    <!-- Include Alerts Partial -->
    <%- include('../partials/alerts') %>

    <div id="booking-system" class="booking-page">
        <% 
            // Safe fallback handling for preFilled (only package, services, price allowed)
            const data = typeof preFilled !== 'undefined' ? preFilled : { packageName: null, services: [], totalPrice: 0 };
            const isManual = typeof isManualBooking !== 'undefined' ? isManualBooking : false;
        %>
        
        <div class="container">
            <div class="row justify-content-center">
                <!-- Left: Package Summary OR Package Selection -->
                <div class="col-lg-4 mb-4">
                    <% if (isManual) { %>
                        <div class="summary-card glass-effect manual-selection">
                            <h3 class="summary-title text-center">Select Package</h3>
                            <hr class="gold-line">
                            <p class="text-center small text-soft-white mb-4">Please choose a package to continue</p>
                            
                            <div class="package-options-grid">
                                <div class="package-option-item" onclick="selectManualPackage('Basic Package', 51000, 'Traditional Photo, Traditional Video')">
                                    <div class="option-content">
                                        <span class="option-name">Basic</span>
                                        <span class="option-price">₹ 51,000</span>
                                    </div>
                                </div>
                                <div class="package-option-item" onclick="selectManualPackage('Standard Package', 75000, 'Trad. Photo & Video, Candid Photo, 30p Album')">
                                    <div class="option-content">
                                        <span class="option-name">Standard</span>
                                        <span class="option-price">₹ 75,000</span>
                                    </div>
                                </div>
                                <div class="package-option-item" onclick="selectManualPackage('Premium Package', 149000, 'Full Wedding Coverage, Candid + Cinematic, 2 Albums')">
                                    <div class="option-content">
                                        <span class="option-name">Premium</span>
                                        <span class="option-price">₹ 1,49,000</span>
                                    </div>
                                </div>
                                <a href="/custom-package" class="package-option-item custom">
                                    <div class="option-content">
                                        <span class="option-name">Custom</span>
                                        <span class="option-price">Build Yours</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="summary-card glass-effect">
                            <h3 class="summary-title text-center">Selected Package</h3>
                            <hr class="gold-line">
                            
                            <div id="summary-details">
                                <% if (data.packageName) { %>
                                    <div class="summary-item">
                                        <label><i class="bi bi-box-seam me-2"></i> Package Name</label>
                                        <p class="text-gold fw-bold"><%= data.packageName %></p>
                                    </div>
                                <% } %>

                                <% if (data.services && data.services.length > 0) { %>
                                    <div class="summary-item mt-3">
                                        <label><i class="bi bi-camera me-2"></i> Included Services</label>
                                        <ul class="list-unstyled service-list mt-2">
                                            <% data.services.forEach(service => { %>
                                                <li class="mb-1"><i class="bi bi-check2-circle text-gold me-2"></i><%= service %></li>
                                            <% }); %>
                                        </ul>
                                    </div>
                                <% } %>

                                <div class="summary-item mt-4 pt-3 border-top border-secondary">
                                    <label class="fs-6">Total Net Rate</label>
                                    <h2 class="total-price fw-bold">₹ <%= data.totalPrice.toLocaleString('en-IN') %></h2>
                                </div>
                            </div>
                        </div>
                    <% } %>
                    
                    <div class="booking-info-box mt-4">
                        <p class="mb-0 small"><i class="bi bi-info-circle-fill me-2"></i> <%= isManual ? 'Select a package and fill the form to proceed.' : 'Please provide your event details manually in the form to proceed.' %></p>
                    </div>
                </div>

                <!-- Right: Booking Form (Manual Entry) -->
                <div class="col-lg-7">
                    <div class="booking-form-card glass-effect">
                        <h2 class="form-title">Event Details</h2>
                        <p class="form-subtitle">Tell us about your special day</p>

                        <form action="/booking" method="POST" id="mainBookingForm" novalidate>
                            <!-- Hidden Fields to store pre-filled data for backend -->
                            <input type="hidden" name="packageName" id="hiddenPackageName" value="<%= data.packageName %>">
                            <input type="hidden" name="totalPrice" id="hiddenTotalPrice" value="<%= data.totalPrice %>">
                            <input type="hidden" name="services" id="hiddenServices" value="<%= data.services.join(',') %>">

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label class="form-label"><i class="bi bi-person-fill me-2"></i> Your Name <span class="text-danger">*</span></label>
                                    <input type="text" name="name" class="form-control" placeholder="Enter your full name" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label"><i class="bi bi-envelope-fill me-2"></i> Email Address <span class="text-danger">*</span></label>
                                    <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label"><i class="bi bi-telephone-fill me-2"></i> Phone Number <span class="text-danger">*</span></label>
                                    <input type="tel" name="phone" class="form-control" placeholder="Enter mobile number" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label"><i class="bi bi-calendar-check me-2"></i> Start Date <span class="text-danger">*</span></label>
                                    <input type="date" name="startDate" id="startDate" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label"><i class="bi bi-calendar-check me-2"></i> End Date <span class="text-danger">*</span></label>
                                    <input type="date" name="endDate" id="endDate" class="form-control" required>
                                </div>
                                <div id="dateError" class="col-12 text-danger small mb-3 d-none">
                                    End date cannot be before start date ❌
                                </div>
                                <div class="col-12 mb-4">
                                    <label class="form-label"><i class="bi bi-geo-alt-fill me-2"></i> Event Location <span class="text-danger">*</span></label>
                                    <input type="text" name="place" class="form-control" placeholder="Venue details or City" required>
                                </div>
                                
                                <div class="col-12 mt-2">
                                    <button type="submit" class="btn btn-booking-submit w-100">
                                        Submit Booking Request
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Partial -->
    <%- include('../partials/footer') %>

    <!-- Custom Scripts -->
    <script src="/js/script.js"></script>
    <script src="/js/footer.js"></script>
    <script src="/js/nav.js"></script>
    <script src="/js/booking.js"></script>
    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
