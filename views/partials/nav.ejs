<!-- views/partials/nav.ejs -->

<!-- Premium Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- Navbar Styles -->
<link rel="stylesheet" href="/css/nav.css">

<style>
    :root {
        --cloudinary-base-url: url('<%= cloudinaryBaseUrl %>');
    }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<!-- Navbar Section -->
<nav class="navbar navbar-expand-lg fixed-top bg-transparent" id="mainNavbar">
    <div class="container">
        <!-- Logo (Always on the Left) -->
        <a class="navbar-brand" href="/">Utsava Click</a>

        <!-- Right Icons Section (Always Visible) -->
        <div class="d-flex align-items-center ms-auto order-lg-last">
            <!-- Notification Bell -->
            <% if (user) { %>
                <div class="dropdown mx-2">
                    <a class="nav-link position-relative p-1" href="#" id="notifDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-bell fs-3"></i>
                        <% let count = (typeof unreadCount !== 'undefined') ? unreadCount : 0; %>
                        <% if (count > 0) { %>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem; padding: 0.35em 0.5em;">
                                <%= count %>
                            </span>
                        <% } %>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end bg-dark border-gold notification-dropdown shadow-lg" aria-labelledby="notifDropdown">
                        <li class="dropdown-header text-gold border-bottom border-gold mb-2 d-flex justify-content-between align-items-center">
                            <span>Notifications</span>
                            <button type="button" class="btn-close btn-close-white d-lg-none" id="closeNotifications" aria-label="Close"></button>
                        </li>
                        <% if (notifications && notifications.length > 0) { %>
                            <% notifications.forEach(notif => { %>
                                <li>
                                    <a class="dropdown-item text-white py-2 <%= notif.isRead ? 'opacity-50' : 'fw-bold' %>" href="#" onclick="markRead('<%= notif._id %>')">
                                        <div class="small text-wrap"><%= notif.message %></div>
                                        <div class="text-muted" style="font-size: 0.75rem;"><%= new Date(notif.createdAt).toLocaleDateString() %></div>
                                    </a>
                                </li>
                            <% }); %>
                        <% } else { %>
                            <li><a class="dropdown-item text-muted small py-3 text-center">No new notifications</a></li>
                        <% } %>
                    </ul>
                    <div class="notification-backdrop d-lg-none" id="notifBackdrop"></div>
                </div>
            <% } %>

            <!-- User Section (Always Visible on mobile as icon, full on desktop) -->
            <% if (user) { %>
                <div class="dropdown mx-1">
                    <a class="nav-link dropdown-toggle text-gold fw-bold d-flex align-items-center p-1" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle fs-3 me-lg-2"></i>
                        <span class="d-none d-lg-inline">Hi, <%= user.name.split(' ')[0] %></span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end bg-dark border-gold shadow-lg" aria-labelledby="userDropdown">
                        <li><a class="dropdown-item text-white" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
            <% } %>

            <!-- Mobile Toggler -->
            <button class="navbar-toggler border-0 p-0 ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavCollapse" aria-controls="mainNavCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list fs-1 text-white" id="navbarTogglerIcon"></i>
            </button>
        </div>

        <!-- Main Navigation Links (Collapsible) -->
        <div class="collapse navbar-collapse justify-content-end" id="mainNavCollapse">
            <ul class="navbar-nav align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/gallery">Gallery</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/packages">Packages</a>
                </li>
                <!-- More Dropdown -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="moreDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        More
                    </a>
                    <ul class="dropdown-menu bg-dark border-gold dropdown-menu-end shadow-lg" aria-labelledby="moreDropdown">
                        <li><a class="dropdown-item text-white" href="/custom-package">Custom Package</a></li>
                        <li><a class="dropdown-item text-white" href="/feedback">Feedback</a></li>
                    </ul>
                </li>

                <!-- Guest Links in Collapse for mobile, or beside icons for desktop -->
                <% if (!user) { %>
                    <li class="nav-item guest-links d-lg-none">
                        <a class="nav-link" href="/login">Login</a>
                        <a class="nav-link" href="/signup">Signup</a>
                    </li>
                    <li class="nav-item d-none d-lg-flex align-items-center mx-2">
                        <a class="nav-link" href="/login">Login</a>
                        <span class="text-white opacity-50">|</span>
                        <a class="nav-link" href="/signup">Signup</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<!-- Navbar Script -->
<script src="/js/nav.js"></script>
<script>
    async function markRead(id) {
        try {
            const response = await fetch(`/notifications/read/${id}`, { method: 'POST' });
            if (response.ok) {
                location.reload();
            }
        } catch (err) {
            console.error('Error marking notification as read:', err);
        }
    }
</script>
