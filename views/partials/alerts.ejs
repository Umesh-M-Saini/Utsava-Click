<% if (success_msg && success_msg.length > 0) { %>
    <div class="alert-container">
        <div class="custom-alert alert-success animate-fade">
            <span class="alert-icon">🎉</span>
            <span class="alert-message"><%= success_msg %></span>
            <button class="close-alert">&times;</button>
        </div>
    </div>
<% } %>

<% if (error_msg && error_msg.length > 0) { %>
    <div class="alert-container">
        <div class="custom-alert alert-error animate-fade">
            <span class="alert-icon">❌</span>
            <span class="alert-message"><%= error_msg %></span>
            <button class="close-alert">&times;</button>
        </div>
    </div>
<% } %>

<style>
    .alert-container {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        width: 90%;
        max-width: 400px;
    }

    .custom-alert {
        display: flex;
        align-items: center;
        padding: 15px 20px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        color: white;
        font-family: 'Poppins', sans-serif;
        margin-bottom: 10px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .alert-success {
        background: rgba(40, 167, 69, 0.9);
    }

    .alert-error {
        background: rgba(220, 53, 69, 0.9);
    }

    .alert-icon {
        font-size: 1.2rem;
        margin-right: 15px;
    }

    .alert-message {
        flex: 1;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .close-alert {
        background: none;
        border: none;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0;
        margin-left: 15px;
        line-height: 1;
        opacity: 0.7;
        transition: opacity 0.3s;
    }

    .close-alert:hover {
        opacity: 1;
    }

    .animate-fade {
        animation: slideDownFadeIn 0.5s ease forwards;
    }

    @keyframes slideDownFadeIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-out {
        animation: slideUpFadeOut 0.5s ease forwards;
    }

    @keyframes slideUpFadeOut {
        from {
            opacity: 1;
            transform: translateY(0);
        }
        to {
            opacity: 0;
            transform: translateY(-20px);
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const alerts = document.querySelectorAll('.custom-alert');
        alerts.forEach(alert => {
            const closeBtn = alert.querySelector('.close-alert');
            
            const dismissAlert = () => {
                alert.classList.add('fade-out');
                setTimeout(() => {
                    alert.parentElement.remove();
                }, 500);
            };

            closeBtn.addEventListener('click', dismissAlert);

            // Auto-dismiss after 5 seconds
            setTimeout(dismissAlert, 5000);
        });
    });
</script>